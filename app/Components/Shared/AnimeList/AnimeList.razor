@inherits AnimeListBase

@namespace app.Components.Shared

<div class="flex flex-col items-center w-auto">
    <div class="tertiary-background-color golden-border border-2 w-200 max-w-[95vw] flex flex-wrap justify-evenly gap-x-5 rounded-md py-3">
        <button @onclick="@(() => SelectList("now"))" class="@ActiveList("now") cursor-pointer">Current Season</button>
        <button @onclick="@(() => SelectList("ongoing"))" class="@ActiveList("ongoing") cursor-pointer">Ongoing</button>
        <button @onclick="@(() => SelectList("upcoming"))" class="@ActiveList("upcoming") cursor-pointer">Next Season</button>
    </div>
    @if (_jikanResponse is not null)
    {

        <div class="flex items-center w-fit my-5 mx-auto h-10">
            <button
                class="secondary-background-color rounded-l-4xl ms-auto px-3 h-[inherit] hover:brightness-95 active:brightness-90 w-fit cursor-pointer"
                title="Previous Page" disabled="@(!_canGoPrevious)" @onclick="GoToPreviousPage">
                <img src="@SelectIcon("arrow-left")" width="25" height="auto" alt="Arrow Left Icon" />
            </button>

            @if (_jikanResponse.Pagination.has_next_page)
            {
                <span
                    class="flex items-center text-xl px-4 h-[inherit] tertiary-background-color">@_jikanResponse.Pagination.current_page
                    of ?
                </span>
            }
            else
            {
                <span
                    class="flex items-center text-xl px-4 h-[inherit] tertiary-background-color">@_jikanResponse.Pagination.current_page
                    of @_jikanResponse.Pagination.last_visible_page
                </span>
            }
            <button
                class="secondary-background-color rounded-r-4xl ms-auto px-3 h-[inherit] hover:brightness-95 active:brightness-90 w-fit cursor-pointer"
                title="Next Page" disabled="@(!_canGoNext)" @onclick="GoToNextPage">
                <img src="@SelectIcon("arrow-right")" width="25" height="auto" alt="Arrow Right Icon" />
            </button>
        </div>
        @if (_jikanError is not null && _jikanError.Status == 429)
        {
            <div class="error-block mb-5">
                <span>@_jikanError.Message</span>
            </div>
        }
        @if (_errors.Keys.Contains("General")) {
            <div class="error-block mb-5 flex flex-col">
                @foreach(string e in _errors["General"]) {
                    <span>@e</span>
                }
            </div>
        }
    }
    <div
        class="grid grid-cols-2 gap-x-5 w-full gap-y-5 md:w-fit mx-auto md:grid-cols-4 xl:grid-cols-5 xl:gap-x-10 xl:gap-y-5">
        @if (_jikanResponse is not null && _jikanResponse.Data is not null)
        {
            foreach (app.DTOs.Anime anime in _jikanResponse.Data)
            {
                <AnimeItem Anime="anime" InSchedule="@(_animesInSchedule.Any(i => i == anime.MalId))" OnInspection="@(v => _inspectingAnime = v)" />
            }
        }
        else
        {
            @if (_jikanError is null)
            {
                <p>Loading...</p>
            }
            else
            {
                <div class="error-block">
                    <span>@_jikanError.Message</span>
                </div>
            }
        }
    </div>
</div>

<Overlay IsOpen="@(_inspectingAnime is not null)" Changed="@(v => _inspectingAnime = null)">
    <Anime Anime="_inspectingAnime" OnSaveRelay="@(v => UpdateUI(v))" />
</Overlay>