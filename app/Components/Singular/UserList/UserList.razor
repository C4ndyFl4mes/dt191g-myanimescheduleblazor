@inherits UserListBase

@namespace app.Components.Singular

<div class="overflow-x-auto max-w-250 mx-auto">
    <div class="mx-auto min-w-150 rounded-t-xl golden-border border-2 border-b-0 overflow-hidden">
        <table class="w-full border-spacing-0 text-center">
            <thead>
                <tr class="golden-border border-b text-xl">
                    <th class="p-2">Username</th>
                    <th class="p-2">Role</th>
                    <th class="p-2">Timezone</th>
                    <th class="p-2">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (_users is not null)
                {
                    @if (_users.Data.Count != 0)
                    {
                        foreach (UserItemResponse user in _users.Data)
                        {
                            <tr>
                                <td class="p-2">@user.Username</td>
                                <td class="p-2">@user.Role</td>
                                <td class="p-2">@user.TimeZone</td>
                                <td class="p-2">
                                    <div class="flex">
                                        <button @onclick="() => Inspect(user.UserID)"
                                                class="secondary-background-color rounded-md mx-auto px-4 py-1 hover:brightness-95 active:brightness-90 w-fit cursor-pointer">Inspect</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                }
                else
                {
                    @if (errors is null)
                    {
                        <tr>
                            <td colspan="4">Loading...</td>
                        </tr>
                    }

                }
            </tbody>
            <tfoot>
                @if (_successMessage is not null)
                {
                    <tr>
                        <td colspan="4" class="p-0">
                            <div class="success-block w-full">
                                <span>@_successMessage</span>
                            </div>
                        </td>
                    </tr>
                }
                @if (errors is not null && errors.Keys.Contains("General"))
                {
                    <tr>
                        <td colspan="4" class="p-0">
                            <div class="error-block w-full">
                                @foreach (string e in errors["General"])
                                {
                                    <span>@e</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (_users is not null)
                {
                    <tr>
                        <td colspan="4">
                            <div class="flex items-center w-fit my-5 mx-auto h-10">
                                <button
                                    class="secondary-background-color rounded-l-4xl ms-auto px-3 h-[inherit] hover:brightness-95 active:brightness-90 w-fit cursor-pointer"
                                    title="Previous Page" disabled="@(!_canGoPrevious)" @onclick="GoToPreviousPage">
                                    <img src="@SelectIcon("arrow-left")" width="25" height="auto" alt="Arrow Left Icon" />
                                </button>
                                <span
                                    class="flex items-center text-xl px-4 h-[inherit] tertiary-background-color">@_users.Pagination.current_page
                                    of
                                    @_users.Pagination.last_visible_page</span>
                                    <button
                                        class="secondary-background-color rounded-r-4xl ms-auto px-3 h-[inherit] hover:brightness-95 active:brightness-90 w-fit cursor-pointer"
                                        title="Next Page" disabled="@(!_canGoNext)" @onclick="GoToNextPage">
                                        <img src="@SelectIcon("arrow-right")" width="25" height="auto" alt="Arrow Right Icon" />
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tfoot>
            </table>
        </div>
    </div>

    <Overlay IsOpen="_inspectionOverlayOpen" Changed="@(v => _inspectionOverlayOpen = v)">
        <UserInfo Type="Complete" UserID="_inspectingUserID" OnDelete="async (v) => await DeleteUser(v)" />
    </Overlay>